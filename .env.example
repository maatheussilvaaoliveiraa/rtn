# =====================================================================
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA suba o .env real para o GitHub (já está no .gitignore).
# Em produção (GitHub Actions / Streamlit Cloud) estes valores entram
# como "Secrets", não como arquivo.
# =====================================================================

# String de conexão do Neon. Use o driver psycopg3: "postgresql+psycopg://..."
# Pegue no painel do Neon (Connection string) e troque o prefixo
# "postgresql://" por "postgresql+psycopg://".
DATABASE_URL=postgresql+psycopg://usuario:senha@host.neon.tech/dbname?sslmode=require

# Chave da API da Groq (https://console.groq.com/keys) — free tier, sem cartão.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Força uma URL específica de PDF, pulando o scraper.
# Útil para testar ou quando o site do Tesouro mudar de layout.
RTN_PDF_URL=
